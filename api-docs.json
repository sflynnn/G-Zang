{
  "openapi": "3.0.3",
  "info": {
    "title": "G-Zang (归藏) API文档",
    "description": "G-Zang (归藏) 财务管理系统API文档",
    "version": "1.0.0",
    "contact": {
      "name": "G-Zang Team",
      "email": "team@gzang.com"
    },
    "license": {
      "name": "MIT License",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "security": [
    {
      "Bearer Authentication": []
    }
  ],
  "components": {
    "securitySchemes": {
      "Bearer Authentication": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "在请求头中添加 JWT Token：Authorization: Bearer {token}"
      }
    },
    "schemas": {
      "Result": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "响应码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "description": "响应数据"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名（手机号/邮箱）"
          },
          "password": {
            "type": "string",
            "description": "密码"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT Token"
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "description": "用户ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "nickname": {
            "type": "string",
            "description": "用户昵称"
          },
          "avatar": {
            "type": "string",
            "description": "用户头像"
          },
          "roleId": {
            "type": "integer",
            "format": "int64",
            "description": "角色ID"
          },
          "companyId": {
            "type": "integer",
            "format": "int64",
            "description": "公司ID"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "用户ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "password": {
            "type": "string",
            "description": "密码"
          },
          "nickname": {
            "type": "string",
            "description": "用户昵称"
          },
          "avatar": {
            "type": "string",
            "description": "用户头像URL"
          },
          "roleId": {
            "type": "integer",
            "format": "int64",
            "description": "角色ID"
          },
          "companyId": {
            "type": "integer",
            "format": "int64",
            "description": "公司ID"
          },
          "status": {
            "type": "integer",
            "description": "状态 (0:禁用, 1:正常)"
          },
          "createTime": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          },
          "updateTime": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "账户ID"
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "description": "所属用户ID"
          },
          "companyId": {
            "type": "integer",
            "format": "int64",
            "description": "所属公司ID"
          },
          "accountName": {
            "type": "string",
            "description": "账户名称"
          },
          "accountType": {
            "type": "integer",
            "description": "账户类型 (1:现金, 2:银行卡, 3:电子支付)"
          },
          "balance": {
            "type": "number",
            "format": "decimal",
            "description": "当前余额"
          },
          "createTime": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          },
          "updateTime": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "交易ID"
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "description": "记录用户ID"
          },
          "companyId": {
            "type": "integer",
            "format": "int64",
            "description": "所属公司ID"
          },
          "amount": {
            "type": "number",
            "format": "decimal",
            "description": "交易金额"
          },
          "type": {
            "type": "integer",
            "description": "交易类型 (1:收入, 2:支出)"
          },
          "categoryId": {
            "type": "integer",
            "format": "int64",
            "description": "分类ID"
          },
          "accountId": {
            "type": "integer",
            "format": "int64",
            "description": "账户ID"
          },
          "transactionTime": {
            "type": "string",
            "format": "date-time",
            "description": "交易发生时间"
          },
          "remark": {
            "type": "string",
            "description": "备注"
          },
          "relatedBusinessId": {
            "type": "string",
            "description": "关联业务ID"
          },
          "createTime": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          },
          "updateTime": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "分类ID"
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "description": "所属用户ID"
          },
          "companyId": {
            "type": "integer",
            "format": "int64",
            "description": "所属公司ID"
          },
          "categoryName": {
            "type": "string",
            "description": "分类名称"
          },
          "parentId": {
            "type": "integer",
            "format": "int64",
            "description": "父分类ID"
          },
          "type": {
            "type": "integer",
            "description": "类型 (1:收入, 2:支出)"
          },
          "isSystem": {
            "type": "integer",
            "description": "是否系统预设"
          }
        }
      },
      "TransactionSummary": {
        "type": "object",
        "properties": {
          "totalIncome": {
            "type": "number",
            "format": "decimal",
            "description": "总收入"
          },
          "totalExpense": {
            "type": "number",
            "format": "decimal",
            "description": "总支出"
          },
          "netIncome": {
            "type": "number",
            "format": "decimal",
            "description": "净收入"
          },
          "transactionCount": {
            "type": "integer",
            "description": "交易笔数"
          }
        }
      },
      "CategorySummary": {
        "type": "object",
        "properties": {
          "categoryId": {
            "type": "integer",
            "format": "int64",
            "description": "分类ID"
          },
          "categoryName": {
            "type": "string",
            "description": "分类名称"
          },
          "totalAmount": {
            "type": "number",
            "format": "decimal",
            "description": "总金额"
          },
          "transactionCount": {
            "type": "integer",
            "description": "交易笔数"
          }
        }
      }
    }
  },
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "tags": ["认证管理"],
        "summary": "用户登录",
        "description": "用户登录接口，返回JWT Token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {"$ref": "#/components/schemas/Result"},
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/LoginResponse"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "用户名或密码错误"
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["认证管理"],
        "summary": "用户注册",
        "description": "新用户注册接口",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "注册成功"
          },
          "400": {
            "description": "用户名已存在"
          }
        }
      }
    },
    "/api/v1/users/me": {
      "get": {
        "tags": ["用户管理"],
        "summary": "获取当前用户信息",
        "description": "获取当前登录用户的信息",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {"$ref": "#/components/schemas/Result"},
                    {
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users": {
      "get": {
        "tags": ["用户管理"],
        "summary": "获取用户列表",
        "description": "分页获取用户列表",
        "parameters": [
          {
            "name": "current",
            "in": "query",
            "description": "页码",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "每页大小",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/v1/users/{id}": {
      "get": {
        "tags": ["用户管理"],
        "summary": "获取用户信息",
        "description": "根据用户ID获取用户信息",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "用户ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          },
          "404": {
            "description": "用户不存在"
          }
        }
      },
      "put": {
        "tags": ["用户管理"],
        "summary": "更新用户信息",
        "description": "更新指定用户的信息",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "用户ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      },
      "delete": {
        "tags": ["用户管理"],
        "summary": "删除用户",
        "description": "删除指定用户",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "用户ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/v1/accounts": {
      "post": {
        "tags": ["账户管理"],
        "summary": "创建账户",
        "description": "新增一个账户",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Account"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功"
          }
        }
      },
      "get": {
        "tags": ["账户管理"],
        "summary": "获取账户列表",
        "description": "获取用户的账户列表",
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/v1/accounts/page": {
      "get": {
        "tags": ["账户管理"],
        "summary": "分页查询账户",
        "description": "分页获取账户列表",
        "parameters": [
          {
            "name": "current",
            "in": "query",
            "description": "页码",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "每页大小",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "accountType",
            "in": "query",
            "description": "账户类型 (1:现金, 2:银行卡, 3:电子支付)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/v1/accounts/total-balance": {
      "get": {
        "tags": ["账户管理"],
        "summary": "获取总余额",
        "description": "获取用户所有账户的总余额",
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/v1/accounts/{id}": {
      "get": {
        "tags": ["账户管理"],
        "summary": "获取账户详情",
        "description": "根据ID获取账户详情",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "账户ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      },
      "put": {
        "tags": ["账户管理"],
        "summary": "更新账户",
        "description": "更新指定账户信息",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "账户ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Account"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      },
      "delete": {
        "tags": ["账户管理"],
        "summary": "删除账户",
        "description": "删除指定账户",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "账户ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/v1/accounts/{id}/adjust-balance": {
      "post": {
        "tags": ["账户管理"],
        "summary": "调整账户余额",
        "description": "手动调整账户余额",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "账户ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "amount",
            "in": "query",
            "required": true,
            "description": "调整金额",
            "schema": {
              "type": "number",
              "format": "decimal"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/v1/transactions": {
      "post": {
        "tags": ["交易管理"],
        "summary": "创建交易记录",
        "description": "新增一笔交易记录",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Transaction"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      },
      "get": {
        "tags": ["交易管理"],
        "summary": "分页查询交易记录",
        "description": "分页获取交易记录列表",
        "parameters": [
          {
            "name": "current",
            "in": "query",
            "description": "页码",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "每页大小",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "startTime",
            "in": "query",
            "description": "开始时间",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endTime",
            "in": "query",
            "description": "结束时间",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "交易类型 (1:收入, 2:支出)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "categoryId",
            "in": "query",
            "description": "分类ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/v1/transactions/summary": {
      "get": {
        "tags": ["交易管理"],
        "summary": "获取交易汇总",
        "description": "获取交易汇总统计信息",
        "parameters": [
          {
            "name": "startTime",
            "in": "query",
            "description": "开始时间",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endTime",
            "in": "query",
            "description": "结束时间",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/v1/transactions/category-summary": {
      "get": {
        "tags": ["交易管理"],
        "summary": "分类统计",
        "description": "按分类统计交易金额",
        "parameters": [
          {
            "name": "startTime",
            "in": "query",
            "description": "开始时间",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endTime",
            "in": "query",
            "description": "结束时间",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "交易类型 (1:收入, 2:支出)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/v1/transactions/{id}": {
      "get": {
        "tags": ["交易管理"],
        "summary": "获取交易记录详情",
        "description": "根据ID获取交易记录详情",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "交易记录ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      },
      "put": {
        "tags": ["交易管理"],
        "summary": "更新交易记录",
        "description": "更新指定交易记录",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "交易记录ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Transaction"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      },
      "delete": {
        "tags": ["交易管理"],
        "summary": "删除交易记录",
        "description": "删除指定交易记录",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "交易记录ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
