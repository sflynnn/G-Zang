# G-Zang 测试策略规范

## 0. 测试金字塔

```
                    ▲ E2E (少量，高度可信)
                   / \
                  /   \  集成测试 (中量)
                 /───────\
                /  单元测试  \  (大量，快速)
               /─────────────\
目标: 80%+ 测试覆盖来自单元测试
```

---

## 1. 前端单元测试 (Vitest + Vue Test Utils)

### 1.1 组合式函数测试

```typescript
// ✅ Good: useVoiceRecord.spec.ts
import { describe, it, expect, vi, beforeEach } from 'vitest';
import { flushPromises } from '@vue/test-utils';
import { useVoiceRecord } from '../useVoiceRecord';

describe('useVoiceRecord', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  it('should set isRecording to true after starting', async () => {
    const mockStart = vi.fn();
    global.MediaRecorder = vi.fn().mockImplementation(() => ({
      start: mockStart,
      addEventListener: vi.fn(),
    })) as any;

    const { isRecording, startRecording } = useVoiceRecord();
    expect(isRecording.value).toBe(false);
    startRecording();
    await flushPromises();

    expect(isRecording.value).toBe(true);
  });

  it('should handle permission denied error', async () => {
    vi.spyOn(navigator.mediaDevices, 'getUserMedia')
      .mockRejectedValue(new DOMException('Permission denied'));

    const { error, startRecording } = useVoiceRecord();
    startRecording();
    await flushPromises();

    expect(error.value).toBe('请允许麦克风权限');
  });
});
```

### 1.2 组件测试

```typescript
// ✅ Good: QuickRecord.spec.ts
import { mount } from '@vue/test-utils';
import QuickRecord from '../QuickRecord.vue';

describe('QuickRecord.vue', () => {
  it('should emit submit with correct data on form submission', async () => {
    const wrapper = mount(QuickRecord, {
      props: { amount: 100, categoryId: 1 },
    });

    await wrapper.find('[data-testid="submit-btn"]').trigger('click');

    expect(wrapper.emitted('submit')).toBeTruthy();
    expect(wrapper.emitted('submit')[0]).toEqual([{
      amount: 100,
      categoryId: 1,
    }]);
  });

  it('should disable submit button when amount is 0', () => {
    const wrapper = mount(QuickRecord, { props: { amount: 0 } });
    expect(wrapper.find('[data-testid="submit-btn"]').attributes('disabled')).toBeDefined();
  });
});
```

