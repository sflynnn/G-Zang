## 2. 前端 E2E 测试 (Playwright)

```typescript
// ✅ Good: tests/e2e/transaction.spec.ts
import { test, expect } from '@playwright/test';

test.describe('Transaction Management', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/login');
    await page.fill('[name="username"]', 'testuser');
    await page.fill('[name="password"]', 'password');
    await page.click('[data-testid="login-btn"]');
    await page.waitForURL('/transactions');
  });

  test('should create a new expense transaction', async ({ page }) => {
    await page.click('[data-testid="add-btn"]');
    await page.fill('[data-testid="amount-input"]', '150.50');
    await page.selectOption('[data-testid="category-select"]', '餐饮');
    await page.click('[data-testid="save-btn"]');

    const rows = page.locator('[data-testid="transaction-row"]');
    await expect(rows.first().locator('.amount')).toContainText('-150.50');
  });
});
```

