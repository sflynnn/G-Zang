## 3. 后端单元测试 (JUnit 5 + Mockito)

### 3.1 Service 层测试

```java
// ✅ Good: TransactionServiceImplTest.java
@ExtendWith(MockitoExtension.class)
class TransactionServiceImplTest {
    @Mock
    private TransactionMapper transactionMapper;
    @Mock
    private CategoryService categoryService;
    @InjectMocks
    private TransactionServiceImpl transactionService;

    @Test
    @DisplayName("创建交易记录 - 成功")
    void createTransaction_Success() {
        // Arrange
        CreateTransactionDTO dto = new CreateTransactionDTO();
        dto.setAmount(new BigDecimal("150.50"));
        dto.setType((byte) 2);
        dto.setCategoryId(10L);
        dto.setAccountId(1L);

        Account mockAccount = new Account();
        mockAccount.setId(1L);
        mockAccount.setBalance(new BigDecimal("10000"));

        when(categoryService.getById(10L)).thenReturn(new Category());
        when(accountService.getById(1L)).thenReturn(mockAccount);
        when(transactionMapper.insert(any(Transaction.class)))
            .thenAnswer(inv -> { inv.getArgument(0, Transaction.class).setId(1000L); return 1; });

        // Act
        TransactionVO result = transactionService.create(dto, 1L, 100L);

        // Assert
        assertNotNull(result);
        assertEquals(1000L, result.getId());
        verify(transactionMapper).insert(any(Transaction.class));
    }

    @Test
    @DisplayName("创建交易 - 金额不合法")
    void createTransaction_InvalidAmount() {
        CreateTransactionDTO dto = new CreateTransactionDTO();
        dto.setAmount(BigDecimal.ZERO);
        dto.setType((byte) 2);

        assertThrows(BusinessException.class, () ->
            transactionService.create(dto, 1L, 100L)
        );
    }
}
```

### 3.2 Controller 层测试 (WebMvcTest)

```java
// ✅ Good: TransactionControllerTest.java
@WebMvcTest(TransactionController.class)
@AutoConfigureMockMvc
class TransactionControllerTest {
    @Autowired
    private MockMvc mockMvc;
    @MockBean
    private TransactionService transactionService;
    @MockBean
    private JwtUtil jwtUtil;

    @Test
    @DisplayName("GET /api/transactions - 返回分页列表")
    void listTransactions_Success() throws Exception {
        when(jwtUtil.extractUserId(anyString())).thenReturn(1L);
        when(transactionService.page(any(), eq(1L), any()))
            .thenReturn(Page.of(List.of(new TransactionVO()), 1, 20));

        mockMvc.perform(get("/api/transactions")
                .header("Authorization", "Bearer mock-token")
                .param("page", "1"))
            .andExpect(status().isOk())
            .andExpect(jsonPath("$.data.records").isArray());
    }

    @Test
    @DisplayName("POST /api/transactions - 未认证返回401")
    void createTransaction_Unauthorized() throws Exception {
        mockMvc.perform(post("/api/transactions")
                .contentType(MediaType.APPLICATION_JSON)
                .content("{}"))
            .andExpect(status().isUnauthorized());
    }
}
```

