## 3. 财务数字显示规范

```css
/* ✅ Good: 财务数字必须使用等宽字体，确保垂直对齐 */
.amount {
  font-family: var(--font-mono);
  font-variant-numeric: tabular-nums;  /* 数字等宽 */
}

/* 收入 - 利润绿 */
.amount--income {
  color: var(--gzang-success);
}

/* 支出 - 支出红 */
.amount--expense {
  color: var(--gzang-danger);
}

/* 转账 - 主色 */
.amount--transfer {
  color: var(--gzang-primary);
}
```

```vue
<!-- ✅ Good: Vue 组件中使用 -->
<template>
  <span
    class="amount"
    :class="{
      'amount--income': type === 1,
      'amount--expense': type === 2,
      'amount--transfer': type === 3,
    }"
  >
    {{ formatAmount(amount, type) }}
  </span>
</template>

<script setup lang="ts">
// 收入: +1,000.00
// 支出: -1,000.00
// 转账: 1,000.00
const formatAmount = (amount: number, type: number) => {
  const prefix = type === 1 ? '+' : type === 2 ? '-' : '';
  return `${prefix}${amount.toLocaleString('zh-CN', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2
  })}`;
};
</script>
```

