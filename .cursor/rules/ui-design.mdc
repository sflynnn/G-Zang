## 1. G-Zang 设计令牌

### 1.1 颜色令牌

```css
/* ✅ Good: CSS 变量系统 */
:root {
  /* ================== 品牌色 ================== */
  /* 归藏青 - 品牌主色，用于标题、侧边栏、主文本 */
  --gzang-primary: #0F4C5C;
  --gzang-primary-light: #186a7d;
  --gzang-primary-dark: #0a3644;

  /* 琉璃金 - 强调色，用于 CTA、高亮、VIP 图标 */
  --gzang-secondary: #FB8B24;
  --gzang-secondary-light: #fca03d;
  --gzang-secondary-dark: #e67a1a;

  /* ================== 功能色 ================== */
  --gzang-success: #06D6A0;  /* 利润绿 - 成功状态 */
  --gzang-danger: #EF476F;   /* 支出红 - 错误、警告 */
  --gzang-warning: #FFD166; /* 警示黄 */
  --gzang-info: #118AB2;     /* 信息蓝 */

  /* ================== 中性色 ================== */
  --gzang-bg: #F8F9FA;       /* 浅灰背景 */
  --gzang-surface: #FFFFFF;  /* 卡片背景 */
  --gzang-text-primary: #1F2937;
  --gzang-text-secondary: #6B7280;
  --gzang-border: #E5E7EB;

  /* ================== 语义化别名 ================== */
  --color-text: var(--gzang-text-primary);
  --color-bg: var(--gzang-bg);
  --color-cta: var(--gzang-secondary);
}

/* 深色主题 */
[data-theme="dark"] {
  --gzang-primary: #0a3644;
  --gzang-primary-light: #0F4C5C;
  --gzang-bg: #111827;
  --gzang-surface: #1F2937;
  --gzang-text-primary: #F9FAFB;
  --gzang-text-secondary: #9CA3AF;
  --gzang-border: #374151;
}
```

### 1.2 字体令牌

```css
:root {
  /* UI 界面字体 */
  --font-ui: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  /* 中文文本 */
  --font-cn: 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
  /* 数字/货币（等宽，确保垂直对齐） */
  --font-mono: 'Roboto Mono', 'JetBrains Mono', 'SF Mono', monospace;

  /* 字号 */
  --text-xs: 0.75rem;    /* 12px */
  --text-sm: 0.875rem;   /* 14px */
  --text-base: 1rem;     /* 16px */
  --text-lg: 1.125rem;   /* 18px */
  --text-xl: 1.25rem;    /* 20px */
  --text-2xl: 1.5rem;    /* 24px */
  --text-3xl: 1.875rem;  /* 30px */
  --text-4xl: 2.25rem;   /* 36px */

  /* 字重 */
  --font-normal: 400;
  --font-medium: 500;
  --font-semibold: 600;
  --font-bold: 700;
}
```

### 1.3 间距令牌

```css
:root {
  --space-1: 0.25rem;   /* 4px */
  --space-2: 0.5rem;     /* 8px */
  --space-3: 0.75rem;    /* 12px */
  --space-4: 1rem;       /* 16px */
  --space-5: 1.25rem;    /* 20px */
  --space-6: 1.5rem;     /* 24px */
  --space-8: 2rem;       /* 32px */
  --space-10: 2.5rem;     /* 40px */
  --space-12: 3rem;      /* 48px */
  --space-16: 4rem;      /* 64px */
}
```

### 1.4 阴影令牌

```css
:root {
  /* 柔和浮雕（卡片默认） */
  --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  /* 悬停状态（卡片） */
  --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  /* 弹窗/下拉 */
  --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
}
```

