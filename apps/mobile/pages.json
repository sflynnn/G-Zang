        "navigationBarTitleText": "首页",
        "enablePullDownRefresh": true,
        "backgroundColor": "#f5f5f5"
      }
    },
    {
      "path": "pages/accounting/index",
      "style": {
        "navigationBarTitleText": "记账",
        "backgroundColor": "#f5f5f5"
      }
    },
    {
      "path": "pages/bills/index",
      "style": {
        "navigationBarTitleText": "账单",
        "enablePullDownRefresh": true,
        "backgroundColor": "#f5f5f5"
      }
    },
    {
      "path": "pages/analysis/index",
      "style": {
        "navigationBarTitleText": "统计",
        "backgroundColor": "#f5f5f5"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我的",
        "backgroundColor": "#f5f5f5"
      }
    },
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom",
        "backgroundColor": "#ffffff"
      }
    },
    {
      "path": "pages/accounting/confirm",
      "style": {
        "navigationBarTitleText": "确认记账",
        "backgroundColor": "#f5f5f5"
      }
    },
    {
      "path": "pages/bills/detail",
      "style": {
        "navigationBarTitleText": "账单详情",
        "backgroundColor": "#f5f5f5"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "G-Zang",
    "navigationBarBackgroundColor": "#ffffff",
    "backgroundColor": "#f5f5f5",
    "backgroundTextStyle": "dark",
    "enablePullDownRefresh": false,
    "onReachBottomDistance": 50
  },
  "tabBar": {
    "color": "#7A7E83",
    "selectedColor": "#1989fa",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/home/index",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/accounting/index",
        "iconPath": "static/tabbar/accounting.png",
        "selectedIconPath": "static/tabbar/accounting-active.png",
        "text": "记账"
      },
      {
        "pagePath": "pages/bills/index",
        "iconPath": "static/tabbar/bills.png",
        "selectedIconPath": "static/tabbar/bills-active.png",
        "text": "账单"
      },
      {
        "pagePath": "pages/analysis/index",
        "iconPath": "static/tabbar/analysis.png",
        "selectedIconPath": "static/tabbar/analysis-active.png",
        "text": "统计"
      },
      {
        "pagePath": "pages/profile/index",
        "iconPath": "static/tabbar/profile.png",
        "selectedIconPath": "static/tabbar/profile-active.png",
        "text": "我的"
      }
    ]
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
