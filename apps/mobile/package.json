{
  "name": "g-zang-mobile",
  "version": "1.0.0",
  "description": "G-Zang (归藏) 移动端应用 - uni-app",
  "main": "src/main.ts",
  "scripts": {
    "dev:h5": "cross-env NODE_ENV=development UNI_PLATFORM=h5 vite",
    "dev:app": "cross-env NODE_ENV=development UNI_PLATFORM=app-plus vite",
    "dev:mp-weixin": "cross-env NODE_ENV=development UNI_PLATFORM=mp-weixin vite build --watch",
    "build:h5": "cross-env NODE_ENV=production UNI_PLATFORM=h5 vite build",
    "build:app": "cross-env NODE_ENV=production UNI_PLATFORM=app-plus vite build",
    "build:mp-weixin": "cross-env NODE_ENV=production UNI_PLATFORM=mp-weixin vite build",
    "lint": "eslint --ext .vue,.ts,.js src --fix",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5000720260416001",
    "@dcloudio/uni-app-plus": "3.0.0-alpha-5000720260416001",
    "@dcloudio/uni-components": "3.0.0-alpha-5000720260416001",
    "@dcloudio/uni-h5": "3.0.0-alpha-5000720260416001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5000720260416001",
    "@dcloudio/uni-ui": "1.5.6",
    "@vueuse/core": "^10.6.1",
    "dayjs": "^1.11.10",
    "decimal.js": "^10.4.3",
    "lodash-es": "^4.17.21",
    "pinia": "^2.1.7",
    "vue": "^3.3.8",
    "vue-i18n": "^9.14.0"
  },
  "devDependencies": {
    "@dcloudio/types": "3.4.30",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5000720260416001",
    "@types/lodash-es": "^4.17.12",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/tsconfig": "^0.4.0",
    "autoprefixer": "^10.4.23",
    "cross-env": "^7.0.3",
    "eslint": "^8.51.0",
    "eslint-plugin-vue": "^9.17.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.2.2",
    "vite": "^5.4.0",
    "vue-tsc": "^1.8.19"
  },
  "engines": {
    "node": ">=18.0.0"
  }
