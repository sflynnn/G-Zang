<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gzang.app.mapper.UserMapper">

    <!-- 按公司ID分页查询用户列表 -->
    <select id="selectPageByCompanyId" resultType="com.gzang.app.entity.User">
        SELECT id, username, nickname, avatar, role_id, company_id, status,
               create_time, update_time
        FROM t_user
        WHERE 1=1
        <if test="companyId != null">
            AND company_id = #{companyId}
        </if>
        <if test="companyId == null">
            <!-- companyId 为 null 时，返回所有用户（超级管理员场景） -->
            AND 1=1
        </if>
        ORDER BY id DESC
    </select>

</mapper>
